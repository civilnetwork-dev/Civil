# PostgreSQL
DB_PASSWORD=changeme
# Full connection URL for drizzle-kit (db:migrate, db:studio) and the app
# Docker injects this automatically; for local dev set it manually
DATABASE_URL=postgresql://civil:changeme@localhost:5432/civil

# Redis
REDIS_PASSWORD=changeme

# BetterAuth
BETTER_AUTH_SECRET=at-least-32-random-characters-here

# Patreon OAuth
PATREON_CLIENT_ID=
PATREON_CLIENT_SECRET=

# Optional
PORT=9876

# No Chii domain as it works via Docker without a variable needing
# to be set.
